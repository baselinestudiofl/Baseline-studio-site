}

function renderDashboard() {
  const events = getDB('events');
  const clients = getDB('clients');
  const now = new Date();
  const thisMonth = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0');

  const activeEvents = events.filter(e => ['booked', 'confirmed'].includes(e.status)).length;
  const thisMonthEvents = events.filter(e => e.date.startsWith(thisMonth)).length;
  const openLeads = events.filter(e => ['lead', 'proposal'].includes(e.status)).length;

  let html = '';
  [
    { label: 'Active Events', value: activeEvents },
    { label: 'Total Clients', value: clients.length },
    { label: 'This Month', value: thisMonthEvents },
    { label: 'Open Leads', value: openLeads }
  ].forEach(s => {
    html += `<div class="stat-card"><div class="stat-label">${s.label}</div><div class="stat-value">${s.value}</div></div>`;
  });
  document.getElementById('statCards').innerHTML = html;

  const upcoming = events.sort((a, b) => new Date(a.date) - new Date(b.date)).slice(0, 5);
  let tableHtml = '<table><thead><tr><th>Date</th><th>Event</th><th>Client</th><th>Venue</th><th>Status</th></tr></thead><tbody>';
  upcoming.forEach(e => {
    const date = new Date(e.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    tableHtml += `<tr onclick="openEventDetail('${e.id}')"><td>${date}</td><td>${e.name}</td><td>${e.clientName}</td><td>${e.venueName}</td><td><span class="badge badge-${e.status}">${e.status}</span></td></tr>`;
  });
  tableHtml += '</tbody></table>';
  document.getElementById('upcomingEventsContainer').innerHTML = upcoming.length ? tableHtml : '<div class="empty-state"><div class="empty-state-text">No upcoming events</div></div>';

  const statuses = ['lead', 'proposal', 'booked', 'confirmed'];
  let pillsHtml = '';
  statuses.forEach(status => {
    const count = events.filter(e => e.status === status).length;
    pillsHtml += `<div style="padding: 8px 12px; background: var(--black-3); border: 1px solid var(--border); border-radius: 20px; display: flex; gap: 8px;"><span class="badge badge-${status}">${status}</span><strong>${count}</strong></div>`;
  });
  document.getElementById('pipelinePillsContainer').innerHTML = pillsHtml;
  document.getElementById('newEventBtn').style.display = 'block';
}

function renderPipeline() {
  const events = getDB('events');
  const statuses = ['lead', 'proposal', 'negotiation', 'booked', 'confirmed', 'completed'];
  let html = '';

  statuses.forEach(status => {
    const statusEvents = events.filter(e => e.status === status);
    html += `<div class="kanban-column" data-status="${status}">
      <div class="kanban-header"><div>${status}</div><div class="kanban-count">${statusEvents.length}</div></div>
      <div class="kanban-items" data-status="${status}">`;
    statusEvents.forEach(e => {
      const date = new Date(e.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      html += `<div class="kanban-card" draggable="true" data-event-id="${e.id}" ondragstart="dragStart(event)" ondragend="dragEnd(event)">
        <div class="kanban-card-title">${e.name}</div>
        <div class="kanban-card-client">${e.clientName}</div>
        <div class="kanban-card-date">${date}</div>
        <div class="kanban-card-footer"><div class="kanban-card-price">$${e.basePrice}</div></div>
      </div>`;
    });
    html += `</div></div>`;
  });

  document.getElementById('kanbanBoard').innerHTML = html;
  document.querySelectorAll('.kanban-items').forEach(col => {
    col.addEventListener('dragover', dragOver);
    col.addEventListener('drop', drop);
  });
  document.getElementById('newEventBtn').style.display = 'block';
}

let draggedCard = null;
function dragStart(e) { draggedCard = e.target.closest('.kanban-card'); draggedCard.classList.add('dragging'); }
function dragEnd(e) { if (draggedCard) draggedCard.classList.remove('dragging'); }
function dragOver(e) { e.preventDefault(); }
function drop(e) {
  e.preventDefault();
  const target = e.target.closest('.kanban-items');
  if (target && draggedCard) {
    target.appendChild(draggedCard);
    const newStatus = target.dataset.status;
    const eventId = draggedCard.dataset.eventId;
    const events = getDB('events');
    const event = events.find(e => e.id === eventId);
    if (event) {
      event.status = newStatus;
      setDB('events', events);
      showToast(`Moved to ${newStatus}`, 'success');
    }
  }
}

function renderEvents() {
  let events = getDB('events');
  const searchVal = document.getElementById('eventsSearch')?.value || '';
  const typeFilter = document.getElementById('eventTypeFilter')?.value || '';
  const statusFilter = document.getElementById('eventStatusFilter')?.value || '';

  if (searchVal) events = events.filter(e => e.name.toLowerCase().includes(searchVal.toLowerCase()));
  if (typeFilter) events = events.filter(e => e.type === typeFilter);
  if (statusFilter) events = events.filter(e => e.status === statusFilter);

  let html = '';
  events.forEach(e => {
    const date = new Date(e.date).toLocaleDateString();
    html += `<tr onclick="openEventDetail('${e.id}')"><td>${e.name}</td><td><span class="badge badge-${e.type}">${e.type}</span></td><td>${date}</td><td>${e.clientName}</td><td>${e.venueName}</td><td><span class="badge badge-${e.status}">${e.status}</span></td><td>$${e.basePrice}</td><td><button class="btn btn-secondary" style="padding: 6px 10px; font-size: 12px;" onclick="event.stopPropagation(); deleteEvent('${e.id}');">Delete</button></td></tr>`;
  });
  document.getElementById('eventsTableBody').innerHTML = html || '<tr><td colspan="8"><div class="empty-state"><div class="empty-state-text">No events</div></div></td></tr>';
  document.getElementById('newEventBtn').style.display = 'block';
}

function openEventDetail(eventId) {
  const events = getDB('events');
  const event = events.find(e => e.id === eventId);
  if (!event) return;

  let html = `<div class="modal-title">${event.name} <span class="badge badge-${event.type}">${event.type}</span></div>
    <div class="tabs">
      <button class="tab-btn active" onclick="switchEventTab(this, 'overview')">Overview</button>
      <button class="tab-btn" onclick="switchEventTab(this, 'documents')">Documents</button>
      <button class="tab-btn" onclick="switchEventTab(this, 'portal')">Portal</button>
    </div>
    <div id="tabOverview" class="tab-content active">${renderEventOverview(event)}</div>
    <div id="tabDocuments" class="tab-content">${renderEventDocuments(event)}</div>
    <div id="tabPortal" class="tab-content">${renderEventPortal(event)}</div>`;

  document.getElementById('eventDetailContent').innerHTML = html;
  window.currentEvent = event;
  openModal('eventDetailModal');
}

function switchEventTab(btn, tabName) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.getElementById('tab' + tabName.charAt(0).toUpperCase() + tabName.slice(1)).classList.add('active');
}

