function renderAccounts() {
  const users = getDB('users');
  const currentUser = JSON.parse(localStorage.getItem('bs_current_user'));

  if (!['master', 'admin'].includes(currentUser.role)) {
    document.getElementById('accounts').innerHTML = '<div class="empty-state"><div class="empty-state-text">Access Denied</div></div>';
    return;
  }

  let html = '';
  users.forEach(u => {
    html += `<tr><td>${u.name}</td><td>${u.email}</td><td><span class="badge" style="background: var(--cyan); color: var(--black);">${u.role}</span></td><td><span class="badge" style="background: ${u.active ? 'var(--success)' : 'var(--danger)'};">${u.active ? 'Active' : 'Inactive'}</span></td><td>${new Date(parseInt(u.id.substring(0, 10), 36)).toLocaleDateString()}</td><td><button class="btn btn-secondary" style="padding: 6px 10px; font-size: 12px;" onclick="toggleUserActive('${u.id}')">Toggle</button><button class="btn btn-danger" style="padding: 6px 10px; font-size: 12px;" onclick="deleteUser('${u.id}')">Delete</button></td></tr>`;
  });
  document.getElementById('accountsTableBody').innerHTML = html;
}

function saveAccount(e) {
  e.preventDefault();
  const users = getDB('users');
  users.push({
    id: genId(),
    name: document.getElementById('accountName').value,
    email: document.getElementById('accountEmail').value,
    password: document.getElementById('accountPassword').value,
    phone: document.getElementById('accountPhone').value,
    role: document.getElementById('accountRole').value,
    active: true
  });
  setDB('users', users);
  closeModal('addAccountModal');
  renderAccounts();
  showToast('Created', 'success');
  document.getElementById('addAccountForm').reset();
}

function openAddAccountModal() { document.getElementById('addAccountForm').reset(); openModal('addAccountModal'); }

function toggleUserActive(userId) {
  const users = getDB('users');
  const user = users.find(u => u.id === userId);
  if (user) { user.active = !user.active; setDB('users', users); renderAccounts(); showToast(user.active ? 'Activated' : 'Deactivated', 'success'); }
}

function deleteUser(userId) {
  const users = getDB('users');
  window.confirmCallback = () => {
    const updated = users.filter(u => u.id !== userId);
    setDB('users', updated);
    closeModal('confirmDialog');
    renderAccounts();
    showToast('Deleted', 'success');
  };
  document.getElementById('confirmTitle').textContent = 'Delete User';
  document.getElementById('confirmMessage').textContent = 'Delete this user?';
  openModal('confirmDialog');
}

function renderReports() {
  const events = getDB('events');

  let totalBilled = events.reduce((sum, e) => sum + e.basePrice, 0);
  let collected = events.filter(e => e.depositPaid && e.balancePaid).reduce((sum, e) => sum + e.basePrice, 0);
  let outstanding = totalBilled - collected;

  let html = '';
  [
    { label: 'Total Billed', value: '$' + totalBilled },
    { label: 'Collected', value: '$' + collected },
    { label: 'Outstanding', value: '$' + outstanding }
  ].forEach(s => {
    html += `<div class="stat-card"><div class="stat-label">${s.label}</div><div class="stat-value" style="font-size: 24px;">${s.value}</div></div>`;
  });
  document.getElementById('reportsStats').innerHTML = html;

  const typeChart = {};
  events.forEach(e => { typeChart[e.type] = (typeChart[e.type] || 0) + 1; });
  let typeHtml = '<ul style="list-style: none;">';
  Object.entries(typeChart).forEach(([type, count]) => {
    typeHtml += `<li style="padding: 10px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between;"><span>${type}</span><strong>${count}</strong></li>`;
  });
  document.getElementById('typeChart').innerHTML = typeHtml + '</ul>';

  const statusChart = {};
  events.forEach(e => { statusChart[e.status] = (statusChart[e.status] || 0) + 1; });
  let statusHtml = '<ul style="list-style: none;">';
  Object.entries(statusChart).forEach(([status, count]) => {
    statusHtml += `<li style="padding: 10px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between;"><span class="badge badge-${status}">${status}</span><strong>${count}</strong></li>`;
  });
  document.getElementById('statusChart').innerHTML = statusHtml + '</ul>';
}

function openNewEventModal() {
  const steps = [
    { title: 'Type', content: renderEventTypeStep() },
    { title: 'Basics', content: renderEventBasicsStep() },
    { title: 'Client', content: renderEventClientStep() },
    { title: 'Venue', content: renderEventVenueStep() },
    { title: 'Services', content: renderEventServicesStep() }
  ];

  let html = '';
  steps.forEach((step, idx) => {
    html += `<div id="wizardStep${idx}" class="wizard-step" style="${idx === 0 ? '' : 'display:none;'}"><div style="font-size: 13px; color: var(--gray); margin-bottom: 15px;">Step ${idx + 1} of ${steps.length}</div>${step.content}</div>`;
  });
  html += `<div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px;"><button class="btn btn-secondary" id="wizardBack" onclick="wizardPrevStep()" style="display:none;">Back</button><button class="btn btn-primary" id="wizardNext" onclick="wizardNextStep()">Next</button></div>`;

  document.getElementById('eventWizardSteps').innerHTML = html;
  window.currentWizardStep = 0;
  window.wizardData = {};
  openModal('newEventModal');
}

function renderEventTypeStep() {
  const types = [
    { value: 'wedding', label: 'Wedding', icon: '💒' },
    { value: 'quince', label: 'Quince', icon: '👑' },
    { value: 'corporate', label: 'Corporate', icon: '🏢' }
  ];

  let html = '<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;">';
  types.forEach(t => {
    html += `<div style="background: var(--black-4); border: 2px solid transparent; padding: 20px; border-radius: 8px; cursor: pointer; text-align: center; transition: all 0.2s;" onclick="selectEventType('${t.value}', this)" class="event-type-tile"><div style="font-size: 32px; margin-bottom: 10px;">${t.icon}</div><div style="font-weight: 600;">${t.label}</div></div>`;
  });
  html += '</div>';
  return html;
}

function selectEventType(type, el) {
  document.querySelectorAll('.event-type-tile').forEach(t => t.style.borderColor = 'transparent');
  el.style.borderColor = 'var(--cyan)';
  window.wizardData.type = type;
}

function renderEventBasicsStep() {
  return `<div class="form-group"><label class="form-label">Event Name</label><input type="text" class="form-input" id="wizardEventName" placeholder="e.g., Smith Wedding"></div><div class="form-group"><label class="form-label">Event Date</label><input type="date" class="form-input" id="wizardEventDate"></div><div class="grid-2"><div class="form-group"><label class="form-label">Start Time</label><input type="time" class="form-input" id="wizardStartTime"></div><div class="form-group"><label class="form-label">End Time</label><input type="time" class="form-input" id="wizardEndTime"></div></div>`;
}

function renderEventClientStep() {
  const clients = getDB('clients');
  let html = `<div class="form-group"><label class="form-label">Client</label><select class="form-select" id="wizardClientSelect" onchange="selectWizardClient(this.value)"><option value="new">+ New Client</option>`;
  clients.forEach(c => { html += `<option value="${c.id}">${c.name}</option>`; });
  html += `</select></div><div id="wizardClientForm"><div class="form-group"><label class="form-label">Name</label><input type="text" class="form-input" id="wizardClientName"></div><div class="form-group"><label class="form-label">Email</label><input type="email" class="form-input" id="wizardClientEmail"></div><div class="form-group"><label class="form-label">Phone</label><input type="tel" class="form-input" id="wizardClientPhone"></div></div>`;
  return html;
}

function selectWizardClient(clientId) {
  const form = document.getElementById('wizardClientForm');
  if (clientId === 'new') {
    form.style.display = 'block';
  } else {
    const clients = getDB('clients');
    const client = clients.find(c => c.id === clientId);
    if (client) {
      window.wizardData.clientId = clientId;
      window.wizardData.clientName = client.name;
      window.wizardData.clientEmail = client.email;
      window.wizardData.clientPhone = client.phone;
      form.style.display = 'none';
    }
  }
}

function renderEventVenueStep() {
  const vendors = getDB('vendors').filter(v => v.category === 'venue');
  let html = `<div class="form-group"><label class="form-label">Venue</label><select class="form-select" id="wizardVenueSelect" onchange="selectWizardVenue(this.value)"><option value="new">+ Add New Venue</option>`;
  vendors.forEach(v => { html += `<option value="${v.id}">${v.name}</option>`; });
  html += `</select></div><div id="wizardVenueForm"><div class="form-group"><label class="form-label">Venue Name</label><input type="text" class="form-input" id="wizardVenueName"></div><div class="form-group"><label class="form-label">Address</label><input type="text" class="form-input" id="wizardVenueAddress"></div></div>`;
  return html;
}

function selectWizardVenue(venueId) {
  const form = document.getElementById('wizardVenueForm');
  if (venueId === 'new') {
    form.style.display = 'block';
  } else {
    const vendors = getDB('vendors');
    const venue = vendors.find(v => v.id === venueId);
    if (venue) {
      window.wizardData.venueName = venue.name;
      window.wizardData.venueAddress = venue.contact;
      form.style.display = 'none';
    }
  }
}

function renderEventServicesStep() {
  return `<div class="form-group"><label class="form-label">Services</label><div class="checkbox-group"><label><input type="checkbox" class="wizard-service" value="DJ & Entertainment"> DJ & Entertainment</label><label><input type="checkbox" class="wizard-service" value="Live Sound & Audio"> Live Sound & Audio</label><label><input type="checkbox" class="wizard-service" value="Uplighting"> Uplighting</label><label><input type="checkbox" class="wizard-service" value="LED Video Wall"> LED Video Wall</label></div></div><div class="form-group"><label class="form-label">Base Price</label><input type="number" class="form-input" id="wizardBasePrice" placeholder="2500"></div><div class="form-group"><label class="form-label">Deposit (50%)</label><input type="number" class="form-input" id="wizardDepositAmount" placeholder="1250"></div>`;
}

function wizardNextStep() {
  if (window.currentWizardStep === 0) {
    if (!window.wizardData.type) { showToast('Select event type', 'error'); return; }
  }
  if (window.currentWizardStep === 1) {
    window.wizardData.name = document.getElementById('wizardEventName').value;
    window.wizardData.date = document.getElementById('wizardEventDate').value;
    window.wizardData.startTime = document.getElementById('wizardStartTime').value;
    window.wizardData.endTime = document.getElementById('wizardEndTime').value;
    if (!window.wizardData.name || !window.wizardData.date) { showToast('Fill all fields', 'error'); return; }
  }
  if (window.currentWizardStep === 4) {
    window.wizardData.services = Array.from(document.querySelectorAll('.wizard-service:checked')).map(c => c.value);
    window.wizardData.basePrice = parseInt(document.getElementById('wizardBasePrice').value) || 2500;
    window.wizardData.depositAmount = parseInt(document.getElementById('wizardDepositAmount').value) || 1250;
    createEventFromWizard();
    return;
  }

  window.currentWizardStep++;
  updateWizardDisplay();
}

function wizardPrevStep() {
  if (window.currentWizardStep > 0) {
    window.currentWizardStep--;
    updateWizardDisplay();
  }
}

function updateWizardDisplay() {
  for (let i = 0; i < 5; i++) {
    const el = document.getElementById('wizardStep' + i);
    if (el) el.style.display = i === window.currentWizardStep ? 'block' : 'none';
  }
  document.getElementById('wizardBack').style.display = window.currentWizardStep > 0 ? 'block' : 'none';
  document.getElementById('wizardNext').textContent = window.currentWizardStep === 4 ? 'Create Event' : 'Next';
}

function createEventFromWizard() {
  const events = getDB('events');
  const clients = getDB('clients');

  let clientId = window.wizardData.clientId;
  if (!clientId) {
    const newClient = {
      id: genId(),
      name: document.getElementById('wizardClientName').value,
      email: document.getElementById('wizardClientEmail').value,
      phone: document.getElementById('wizardClientPhone').value,
      type: 'private',
      notes: ''
    };
    clients.push(newClient);
    clientId = newClient.id;
    window.wizardData.clientName = newClient.name;
    window.wizardData.clientEmail = newClient.email;
    window.wizardData.clientPhone = newClient.phone;
    setDB('clients', clients);
  }

  let venueName = window.wizardData.venueName;
  if (!venueName) {
    venueName = document.getElementById('wizardVenueName').value;
    window.wizardData.venueName = venueName;
    window.wizardData.venueAddress = document.getElementById('wizardVenueAddress').value;
  }

  const password = Math.random().toString(36).substring(2, 8).toUpperCase();
  const newEvent = {
    id: genId(),
    name: window.wizardData.name,
    type: window.wizardData.type,
    date: window.wizardData.date,
    startTime: window.wizardData.startTime,
    endTime: window.wizardData.endTime,
    clientId: clientId,
    clientName: window.wizardData.clientName,
    clientEmail: window.wizardData.clientEmail,
    clientPhone: window.wizardData.clientPhone,
    venueName: venueName,
    venueAddress: window.wizardData.venueAddress || '',
    venueContact: '',
    venuePhone: '',
    status: 'lead',
    basePrice: window.wizardData.basePrice,
    depositAmount: window.wizardData.depositAmount,
    depositPaid: false,
    balancePaid: false,
    services: window.wizardData.services,
    staff: [],
    portalPassword: password,
    timeline: [],
    vendors: [],
    music: [],
    documents: [],
    notes: ''
  };

  events.push(newEvent);
  setDB('events', events);
  closeModal('newEventModal');
  renderDashboard();
  showToast('Event created!', 'success');
}

window.addEventListener('DOMContentLoaded', function() {
  initData();
  const currentUser = JSON.parse(localStorage.getItem('bs_current_user'));

  document.getElementById('userAvatar').textContent = currentUser.name.charAt(0);
  document.getElementById('userName').textContent = currentUser.name;
  document.getElementById('userRole').textContent = currentUser.role.replace(/-/g, ' ');

  if (['master', 'admin'].includes(currentUser.role)) {
    document.getElementById('accountsNav').style.display = 'flex';
  }

  document.getElementById('eventsSearch')?.addEventListener('input', renderEvents);
  document.getElementById('eventTypeFilter')?.addEventListener('change', renderEvents);
  document.getElementById('eventStatusFilter')?.addEventListener('change', renderEvents);
  document.getElementById('clientsSearch')?.addEventListener('input', renderClients);
  document.getElementById('vendorsSearch')?.addEventListener('input', renderVendors);
  document.getElementById('vendorCategoryFilter')?.addEventListener('change', renderVendors);

  renderDashboard();
});
