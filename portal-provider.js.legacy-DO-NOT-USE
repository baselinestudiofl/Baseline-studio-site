function switchSection(sectionId) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById(sectionId).classList.add('active');
  document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
  event.target.closest('.nav-link').classList.add('active');

  const titles = { dashboard: 'Dashboard', pipeline: 'Pipeline', events: 'Events', clients: 'Clients', vendors: 'Vendors & Venues', documents: 'Documents', accounts: 'Accounts', reports: 'Reports' };
  document.getElementById('pageTitle').textContent = titles[sectionId];

  if (sectionId === 'dashboard') renderDashboard();
  if (sectionId === 'pipeline') renderPipeline();
  if (sectionId === 'events') renderEvents();
  if (sectionId === 'clients') renderClients();
  if (sectionId === 'vendors') renderVendors();
  if (sectionId === 'documents') renderDocuments();
  if (sectionId === 'accounts') renderAccounts();
  if (sectionId === 'reports') renderReports();
}

function openModal(modalId) { document.getElementById(modalId).classList.add('active'); }
function closeModal(modalId) { document.getElementById(modalId).classList.remove('active'); }

function showToast(message, type = 'info') {
  const container = document.getElementById('toastContainer');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 3500);
}

function logout() {
  localStorage.removeItem('bs_current_user');
